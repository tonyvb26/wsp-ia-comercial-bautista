# Copia este archivo a .env en tu máquina (no subas .env a git).
# En Render/Railway: créalo como variable de entorno WHATSAPP_VERIFY_TOKEN.

# Misma cadena que pegarás en Meta → Token de verificación (elige algo largo y secreto).
WHATSAPP_VERIFY_TOKEN=cambia_por_una_clave_larga_y_secreta

# WhatsApp Cloud API (envío)
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# OpenAI — si está definido, las respuestas las genera el modelo (opcional: OPENAI_MODEL=gpt-4o-mini)
OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
